{
  "name": "Basic Dev Environment",
  "image": "mcr.microsoft.com/devcontainers/base:debian",
  "features": {
    "ghcr.io/oleksis/devcontainer-features/python-launcher:1": {
      "version": "latest"
    },
    "ghcr.io/devcontainers-extra/features/devcontainers-cli:1": {
      "version": "latest"
    },
    "ghcr.io/devcontainer-config/features/dot-config:4": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.debugpy",
        "ms-python.python"
      ]
    }
  },
  "postCreateCommand": ".devcontainer/postCreate.sh"
}